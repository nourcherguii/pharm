DJANGO_SECRET_KEY=dev-secret-auth-only
DJANGO_SECRET_KEY_CATALOG=dev-secret-catalog-only
DJANGO_SECRET_KEY_WEB=dev-secret-web-only
JWT_SIGNING_KEY=shared-jwt-secret-must-match-auth-and-catalog
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# web-ui : devise affichée (pas de conversion automatique — les prix en base = cette unité)
# Algérie : CURRENCY_CODE=DZD  CURRENCY_SYMBOL=DA
# Égypte  : CURRENCY_CODE=EGP  CURRENCY_SYMBOL=ج.م
#           ou CURRENCY_SYMBOL=E£
CURRENCY_CODE=DZD
CURRENCY_SYMBOL=DA

# catalog-api : conversion import drugs_egypt.csv (prix source en EGP) → stockage en DZD
# Ex. si 1 EGP ≈ 2,7 DZD : EGP_TO_DZD_RATE=2.70
EGP_TO_DZD_RATE=2.70
